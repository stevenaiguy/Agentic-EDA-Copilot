      "parameters": {
        "jsCode": "const embedding = $('AI - Local Contrastive Embedding').first().json.embedding;\nconst top_k = $('Process - Privacy Gate').first().json.top_k;\n\n// 在 Code Node 裡直接序列化成字串，保持 array 型別\nconst payload = JSON.stringify({\n  vector: embedding,\n  limit: parseInt(top_k) || 5,\n  with_payload: true\n});\n\nreturn [{ json: { payload } }];\n"
