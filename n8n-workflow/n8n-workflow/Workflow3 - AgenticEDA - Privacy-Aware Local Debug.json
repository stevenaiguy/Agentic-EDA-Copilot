      "parameters": {
        "jsCode": "const rankData = $input.first().json;\nconst snippet = rankData.buggy_snippet;\nconst matches = rankData.matches.slice(0, 3);\n\nconst prompt = `You are an EDA RTL debug expert. Analyze this buggy Verilog snippet and suggest a fix:\\n\\n${snippet}\\n\\nSimilar historical bugs found:\\n${JSON.stringify(matches, null, 2)}\\n\\nProvide a concise fix suggestion.`;\n\nconst payload = JSON.stringify({\n  model: \"qwen3:8b\",\n  prompt: prompt,\n  stream: false  // 真正的 boolean，不是字串\n});\n\nreturn [{ json: { payload } }];\n"
      },
