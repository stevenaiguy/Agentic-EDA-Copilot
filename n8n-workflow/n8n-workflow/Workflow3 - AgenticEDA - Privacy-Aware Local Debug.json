    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\nif (!body.buggy_verilog && !body.buggy_snippet) {\n  throw new Error('Provide buggy_verilog (full RTL) or buggy_snippet (code fragment)');\n}\n\nconst snippet = body.buggy_snippet || body.buggy_verilog.substring(0, 2000);\n\nreturn [{\n  json: {\n    session_id:    body.session_id || `local_${Date.now()}`,\n    buggy_snippet: snippet,\n    context:       body.context || '',\n    top_k:         parseInt(body.top_k, 10) || 5,\n    start_ms:      Date.now(),\n    privacy_mode:  true\n  }\n}];\n"
      },
      "id": "0717eb85-8239-41e0-86ed-70e709cfffbe",
      "name": "Process - Privacy Gate",
      "type": "n8n-nodes-base.code",
