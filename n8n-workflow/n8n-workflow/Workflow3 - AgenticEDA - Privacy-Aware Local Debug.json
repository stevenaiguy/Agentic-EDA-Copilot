      "id": "3aaee899-3b90-4f93-8fe3-b5d05718b263",
      "name": "AI - Local Contrastive Embedding",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        288,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "// Rank and format historical bug matches (all local, no cloud)\nconst searchResults = $input.first().json;\nconst inputCtx      = $('Process - Privacy Gate').first().json;\n\nconst matches = (searchResults.result || []).map(hit => ({\n  score:       hit.score,\n  bug_type:    hit.payload.bug_type,\n  description: hit.payload.description,\n  fix_patch:   hit.payload.fix_patch,\n  verilog_ref: hit.payload.verilog_ref,\n  source:      'local_bug_db'  // Confirm data source is local\n}));\n\n// Confidence tier logic\nconst topScore = matches.length > 0 ? matches[0].score : 0;\nlet confidence_tier = 'LOW';\nif (topScore >= 0.90)      confidence_tier = 'HIGH';\nelse if (topScore >= 0.75) confidence_tier = 'MEDIUM';\n\nreturn [{\n  json: {\n    session_id:      inputCtx.session_id,\n    privacy_mode:    true,\n    data_stayed_local: true,\n    confidence_tier,\n    top_match_score: topScore,\n    matches,\n    buggy_snippet:   inputCtx.buggy_snippet,\n    latency_ms:      Date.now() - inputCtx.start_ms\n  }\n}];"
      },
      "id": "65007e9e-c935-492d-8917-fe6c44c66a7e",
      "name": "Process - Rank Bug Matches",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "// Final response assembly with privacy attestation\nconst llmResp  = $input.first().json;\nconst rankData = $('Process - Rank Bug Matches').first().json;\n\nreturn [{\n  json: {\n    success:           true,\n    session_id:        rankData.session_id,\n    privacy_attestation: {\n      data_stayed_local:  true,\n      cloud_api_used:     false,\n      embedding_model:    'code-bert-verilog (local)',\n      llm_model:          'codellama:13b (Ollama local)'\n    },\n    confidence_tier:   rankData.confidence_tier,\n    top_match_score:   rankData.top_match_score,\n    llm_fix_suggestion: llmResp.response || '',\n    historical_matches: rankData.matches,\n    latency_ms:        rankData.latency_ms\n  }\n}];"
      },
