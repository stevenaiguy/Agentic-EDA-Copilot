    {
      "parameters": {
        "jsCode": "// Neuro-symbolic Guardrail: Validate LLM output against EDA rules\nconst lightragResp  = $input.first().json;\nconst sessionMeta   = $('Integrate - Postgres Fetch Session').first().json;\nconst inputCtx      = $('Process - Validate Input').first().json;\n\nconst answer = lightragResp.answer || lightragResp.response || '';\nconst rawChunks = lightragResp.chunks || lightragResp.references || [];\n\n// === Guardrail Layer: Rule-based verification ===\nconst guardrail = {\n  passed: true,\n  warnings: [],\n  drc_flags: []\n};\n\n// G1: Reject if LLM suggests changing clock frequency without STA confirmation\nif (/increase.*clock|faster.*clock|reduce.*period/i.test(answer)) {\n  guardrail.warnings.push('⚠️ GUARDRAIL G1: Clock change suggestion requires STA verification before implementation.');\n}\n\n// G2: Reject direct GDS modification suggestions\nif (/gds|layout.*edit|direct.*mask/i.test(answer)) {\n  guardrail.drc_flags.push('🚫 GUARDRAIL G2: Direct layout modification detected — must pass DRC before applying.');\n  guardrail.passed = false;\n}\n\n//// G3: Flag multi-driven net fixes that might introduce new violations\n//if (/remove.*driver|disconnect.*net/i.test(answer)) {\n//  guardrail.warnings.push('⚠️ GUARDRAIL G3: Net topology change — re-run formal equivalence check after applying fix.');\n//}\n// G3: Flag multi-driven net fixes\nif (/remov\\S*.*driver|disconnect.*net|eliminat\\S*.*driver/i.test(answer)) {\n  guardrail.warnings.push('⚠️ GUARDRAIL G3: Net topology change — re-run formal equivalence check after applying fix.');\n}\n\n// Extract structured violations from raw chunks\nconst violations = rawChunks.slice(0, 5).map(c => ({\n  severity: (c.metadata && c.metadata.severity) || 'UNKNOWN',\n  message:  (c.text || c.content || '').substring(0, 300),\n  location: (c.metadata && (c.metadata.file ? `${c.metadata.file}:${c.metadata.file_line}` : c.metadata.net)) || 'N/A',\n  score:    c.score || 0\n}));\n\nreturn [{\n  json: {\n    success: true,\n    log_id:     inputCtx.log_id,\n    tool:       sessionMeta.tool_name,\n    query:      inputCtx.query,\n    diagnosis:  answer,\n    violations,\n    guardrail,\n    session_stats: {\n      error_count:        sessionMeta.error_count,\n      warning_count:      sessionMeta.warning_count,\n      timing_violations:  sessionMeta.timing_violations\n    },\n    latency_ms: Date.now() - inputCtx.start_ms\n  }\n}];"
      },
