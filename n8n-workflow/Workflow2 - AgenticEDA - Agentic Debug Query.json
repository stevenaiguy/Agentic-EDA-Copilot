        "jsCode": "const body = $input.first().json.body;\n\nif (!body.query || !body.log_id) {\n  throw new Error('Missing required: query, log_id');\n}\n\nreturn [{\n  json: {\n    query:    body.query,\n    log_id:   body.log_id,\n    file_id:  body.file_id || null,\n    severity: body.severity || 'ERROR',\n    top_k:    parseInt(body.top_k, 10) || 5,\n    start_ms: Date.now()\n  }\n}];"
      },
